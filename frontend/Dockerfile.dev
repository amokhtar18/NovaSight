# NovaSight Frontend Dockerfile (Development)
# =============================================
# Hot-reload enabled development container

FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Copy application source
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Ensure mounted node_modules stays in sync with package-lock on each container start.
CMD ["sh", "-c", "npm ci && npm run dev -- --host 0.0.0.0"]
