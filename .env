# ============================================
# NovaSight Environment Configuration
# ============================================
# Copy this file to .env and customize values
# NEVER commit .env to version control

# ============================================
# Application Settings
# ============================================
APP_NAME=NovaSight
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# ============================================
# Security Keys (CHANGE IN PRODUCTION!)
# ============================================
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32
CREDENTIAL_ENCRYPTION_KEY=your-32-byte-encryption-key-here!!

# ============================================
# PostgreSQL (Metadata Store)
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=novasight_platform
POSTGRES_USER=novasight
POSTGRES_PASSWORD=novasight
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ============================================
# ClickHouse (Data Warehouse)
# ============================================
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=novasight

# ============================================
# Redis (Cache & Sessions)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ============================================
# Apache Airflow
# ============================================
AIRFLOW_HOST=airflow-webserver
AIRFLOW_PORT=8080
AIRFLOW_BASE_URL=http://${AIRFLOW_HOST}:${AIRFLOW_PORT}
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# Airflow Database
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_POSTGRES_DB=airflow

# ============================================
# Apache Spark
# ============================================
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077
SPARK_MASTER_URL=spark://${SPARK_MASTER_HOST}:${SPARK_MASTER_PORT}
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2

# ============================================
# Ollama (Local LLM)
# ============================================
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://${OLLAMA_HOST}:${OLLAMA_PORT}
OLLAMA_MODEL=llama3.2

# ============================================
# Frontend
# ============================================
VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ============================================
# Pagination
# ============================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================
# File Upload
# ============================================
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=/tmp/uploads

# ============================================
# Email (Optional - for notifications)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@novasight.dev
SMTP_USE_TLS=true
