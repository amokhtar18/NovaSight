# ============================================
# NovaSight Environment Configuration
# ============================================
# Copy this file to .env and customize values
# NEVER commit .env to version control

# ============================================
# Application Settings
# ============================================
APP_NAME=NovaSight
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# ============================================
# Test Credentials
# ============================================
TEST_USER_EMAIL=admin@novasight.dev
TEST_USER_PASSWORD=Admin123!

# ============================================
# Security Keys (CHANGE IN PRODUCTION!)
# ============================================
SECRET_KEY=novasight-dev-secret-key-change-in-production-32chars
JWT_SECRET_KEY=novasight-jwt-secret-key-change-in-production-32
CREDENTIAL_ENCRYPTION_KEY=novasight-encryption-key-32byte!

# ============================================
# PostgreSQL (Metadata Store)
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=novasight_platform
POSTGRES_USER=novasight
POSTGRES_PASSWORD=novasight
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ============================================
# ClickHouse (Data Warehouse)
# ============================================
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=default
CLICKHOUSE_DATABASE=novasight

# ============================================
# Redis (Cache & Sessions)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redistest123!
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ============================================
# Apache Airflow
# ============================================
AIRFLOW_HOST=airflow-webserver
AIRFLOW_PORT=8080
AIRFLOW_BASE_URL=http://${AIRFLOW_HOST}:${AIRFLOW_PORT}
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# Airflow Database
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_POSTGRES_DB=airflow

# ============================================
# S3 / Object Storage (Iceberg data lake)
# ============================================
# This storage is the source of Iceberg files that dbt (dbt-duckdb)
# materializes into ClickHouse marts. Replaces the legacy Spark layer.
# See infrastructure/s3/ for full configuration.
S3_ENDPOINT_URL=http://minio:9000
AWS_REGION=us-east-1
S3_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_USE_SSL=false
S3_URL_STYLE=path
S3_BUCKET_PATTERN=novasight-{slug}

# MinIO (dev S3 implementation)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT_URL=http://minio:9000

# Iceberg SQL catalog (Postgres-backed)
ICEBERG_CATALOG_TYPE=sql
ICEBERG_CATALOG_NAME=novasight
ICEBERG_CATALOG_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
ICEBERG_CATALOG_URL=${ICEBERG_CATALOG_URI}
ICEBERG_WAREHOUSE=s3://novasight/

# DuckDB (used by dbt-duckdb lake target to read Iceberg)
DUCKDB_THREADS=4
DUCKDB_MEMORY_LIMIT=4GB

# ============================================
# Ollama (Local LLM)
# ============================================
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://${OLLAMA_HOST}:${OLLAMA_PORT}
OLLAMA_MODEL=qwen3-vl:8b

# ============================================
# Frontend
# ============================================
VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ============================================
# Pagination
# ============================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================
# File Upload
# ============================================
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=/tmp/uploads

# ============================================
# Email (Optional - for notifications)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@novasight.dev
SMTP_USE_TLS=true
