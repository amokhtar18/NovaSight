__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/
ENV/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS
.DS_Store
Thumbs.db

# Docker volumes data
postgres_data/
clickhouse_data/
redis_data/
# Test coverage
.coverage
htmlcov/
.pytest_cache/
coverage.xml
*.cover

# Logs
*.log
logs/

# Build outputs
frontend/dist/
backend/build/

# Temporary files
*.tmp
*.temp
.tmp/
.temp/

# Jupyter
.ipynb_checkpoints/

# Security scan reports
security/reports/*.html
security/reports/*.json

# Tenant file storage (user-uploaded data files)
backend/file_storage/
file_storage/
