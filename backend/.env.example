# NovaSight Environment Configuration
# =====================================
# Copy this file to .env and customize for your environment

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# PostgreSQL (Metadata Store)
DATABASE_URL=postgresql://novasight:novasight@localhost:5432/novasight_platform

# Redis (Cache & Sessions)
REDIS_URL=redis://localhost:6379/0

# ClickHouse (Data Warehouse)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=novasight

# Apache Airflow
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=DEBUG

# Credential Encryption (32+ bytes recommended)
CREDENTIAL_ENCRYPTION_KEY=your-32-byte-encryption-key-here!!

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
