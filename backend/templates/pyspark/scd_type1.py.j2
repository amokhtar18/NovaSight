logger = logging.getLogger("{{ app_name }}")


class SCDType1Job:
    """
    SCD Type 1 job for {{ app_name }}.
    
    Source: {{ connection.db_type }} - {{ connection.host }}:{{ connection.port }}/{{ connection.database }}
    Target: {{ target.database }}.{{ target.table }}
    Primary Keys: {{ primary_keys | join(', ') }}
{% if cdc.column %}
    CDC Column: {{ cdc.column }} ({{ cdc.type }})
{% endif %}
    """
    
    def __init__(self, spark: SparkSession):
        self.spark = spark
        self.app_name = "{{ app_name }}"
        self.app_id = "{{ app_id }}"
        
        # Source configuration
        self.source_config = {
            "db_type": "{{ connection.db_type }}",
            "host": os.getenv("SOURCE_DB_HOST", "{{ connection.host }}"),
            "port": int(os.getenv("SOURCE_DB_PORT", "{{ connection.port }}")),
            "database": "{{ connection.database }}",
            "schema": "{{ connection.schema | default('public', true) }}",
            "username": os.getenv("SOURCE_DB_USER", "{{ connection.username }}"),
            "password": os.getenv("SOURCE_DB_PASSWORD", "{{ connection.password | default('', true) }}"),
        }
        
        # Target configuration
        self.target_config = {
            "database": "{{ target.database }}",
            "table": "{{ target.table }}",
            "engine": "{{ target.engine | default('ReplacingMergeTree', true) }}",
        }
        
        # SCD configuration
        self.primary_keys = [
{% for pk in primary_keys %}
            "{{ pk }}",
{% endfor %}
        ]
        
{% if cdc.column %}
        # CDC configuration
        self.cdc_column = "{{ cdc.column }}"
        self.cdc_type = "{{ cdc.type }}"
{% else %}
        self.cdc_column = None
        self.cdc_type = None
{% endif %}
        
        # Job configuration
        self.batch_size = {{ options.batch_size | default(10000, true) }}
        
        # Column type mappings: source column -> ClickHouse type
        # Generated from source database type: {{ connection.db_type }}
        self.column_type_mapping = {
{% for col in columns %}
            "{{ col.name }}": "{{ col.data_type | to_clickhouse_type(connection.db_type) }}",
{% endfor %}
        }
        
        # Metadata column types for ClickHouse
        self.metadata_columns = {
            "_novasight_app_id": "String",
            "_novasight_extracted_at": "DateTime64(3)",
            "_novasight_updated_at": "DateTime64(3)",
            "_novasight_is_deleted": "UInt8",
        }
        
    def get_jdbc_url(self) -> str:
        """Build JDBC URL based on database type."""
        db_type = self.source_config["db_type"]
        host = self.source_config["host"]
        port = self.source_config["port"]
        database = self.source_config["database"]
        
        jdbc_drivers = {
            "postgresql": f"jdbc:postgresql://{host}:{port}/{database}",
            "mysql": f"jdbc:mysql://{host}:{port}/{database}",
            "oracle": f"jdbc:oracle:thin:@{host}:{port}:{database}",
            "sqlserver": f"jdbc:sqlserver://{host}:{port};databaseName={database}",
        }
        
        return jdbc_drivers.get(db_type, f"jdbc:postgresql://{host}:{port}/{database}")
    
    def get_jdbc_driver(self) -> str:
        """Get JDBC driver class name."""
        drivers = {
            "postgresql": "org.postgresql.Driver",
            "mysql": "com.mysql.cj.jdbc.Driver",
            "oracle": "oracle.jdbc.OracleDriver",
            "sqlserver": "com.microsoft.sqlserver.jdbc.SQLServerDriver",
        }
        return drivers.get(self.source_config["db_type"], "org.postgresql.Driver")
    
    def get_clickhouse_create_table_ddl(self) -> str:
        """
        Generate CREATE TABLE DDL for ClickHouse with proper type mappings.
        Uses ReplacingMergeTree engine for SCD Type 1 (to handle updates).
        
        Returns:
            CREATE TABLE DDL string
        """
        target_db = self.target_config["database"]
        target_table = self.target_config["table"]
        engine = self.target_config.get("engine", "ReplacingMergeTree")
        
        # Build column definitions with mapped ClickHouse types
        column_defs = []
        for col_name, ch_type in self.column_type_mapping.items():
            column_defs.append(f"    `{col_name}` Nullable({ch_type})")
        
        # Add metadata columns (not nullable)
        for col_name, ch_type in self.metadata_columns.items():
            column_defs.append(f"    `{col_name}` {ch_type}")
        
        columns_str = ",\n".join(column_defs)
        
        # Use primary keys for ORDER BY (required for ReplacingMergeTree)
        pk_cols = ", ".join([f"`{pk}`" for pk in self.primary_keys])
        order_by_clause = f"ORDER BY ({pk_cols})" if pk_cols else "ORDER BY tuple()"
        
{% if target.partition_by %}
        partition_clause = "PARTITION BY {{ target.partition_by }}"
{% else %}
        partition_clause = ""
{% endif %}
        
        # For SCD Type 1, use ReplacingMergeTree with _novasight_updated_at as version
        ddl = f"""
CREATE TABLE IF NOT EXISTS `{target_db}`.`{target_table}`
(
{columns_str}
)
ENGINE = {engine}(_novasight_updated_at)
{order_by_clause}
{partition_clause}
""".strip()
        
        return ddl
    
    def ensure_target_table(self):
        """
        Ensure the target ClickHouse table exists with correct schema.
        
        Creates the table if it doesn't exist, using the column type mappings
        derived from the source database types.
        """
        target_url = os.getenv("CLICKHOUSE_HOST", "clickhouse")
        target_port = int(os.getenv("CLICKHOUSE_PORT", "8123"))
        target_user = os.getenv("CLICKHOUSE_USER", "default")
        target_password = os.getenv("CLICKHOUSE_PASSWORD", "")
        
        try:
            import clickhouse_connect
            
            client = clickhouse_connect.get_client(
                host=target_url,
                port=target_port,
                username=target_user,
                password=target_password,
            )
            
            ddl = self.get_clickhouse_create_table_ddl()
            logger.info(f"Creating target table if not exists:\n{ddl}")
            
            client.command(ddl)
            logger.info(f"Target table ensured: {self.target_config['database']}.{self.target_config['table']}")
            
        except Exception as e:
            logger.warning(f"Could not ensure target table via DDL (will rely on JDBC auto-create): {e}")
    
    def get_high_watermark(self) -> str:
        """Get high watermark from state store for CDC."""
{% if cdc.column %}
        # In production, this would read from a state store
        watermark_file = f"/tmp/watermark_{self.app_id}.txt"
        try:
            with open(watermark_file, 'r') as f:
                return f.read().strip()
        except FileNotFoundError:
            return None
{% else %}
        return None
{% endif %}
    
    def save_high_watermark(self, value: str):
        """Save high watermark to state store."""
{% if cdc.column %}
        watermark_file = f"/tmp/watermark_{self.app_id}.txt"
        with open(watermark_file, 'w') as f:
            f.write(str(value))
        logger.info(f"Saved high watermark: {value}")
{% else %}
        pass
{% endif %}
    
    def read_source(self) -> DataFrame:
        """Read data from source database with optional CDC filtering."""
        logger.info(f"Reading from source: {self.source_config['database']}")
        
        jdbc_url = self.get_jdbc_url()
        jdbc_driver = self.get_jdbc_driver()
        
        connection_props = {
            "user": self.source_config["username"],
            "password": self.source_config["password"],
            "driver": jdbc_driver,
            "fetchsize": str(self.batch_size),
        }
        
{% if source.type == 'query' %}
        # Base query
        base_query = """{{ source.query | replace('\n', ' ') }}"""
{% else %}
        # Table reference
        table_name = "{% if source.schema %}{{ source.schema }}.{% endif %}{{ source.table }}"
        base_query = f"SELECT * FROM {table_name}"
{% endif %}
        
{% if cdc.column %}
        # Apply CDC filter if high watermark exists
        high_watermark = self.get_high_watermark()
        if high_watermark:
{% if cdc.type == 'timestamp' %}
            query = f"SELECT * FROM ({base_query}) sq WHERE {{ cdc.column }} > '{high_watermark}'"
{% elif cdc.type == 'version' %}
            query = f"SELECT * FROM ({base_query}) sq WHERE {{ cdc.column }} > {high_watermark}"
{% else %}
            query = base_query
{% endif %}
            logger.info(f"CDC filter applied: {{ cdc.column }} > {high_watermark}")
        else:
            query = base_query
            logger.info("No high watermark found, processing all data")
{% else %}
        query = base_query
{% endif %}
        
        df = self.spark.read.jdbc(
            url=jdbc_url,
            table=f"({query}) AS source_data",
            properties=connection_props
        )
        
        # Select only configured columns
        selected_columns = [
{% for col in columns %}
            "{{ col.name }}",
{% endfor %}
        ]
        
        df = df.select([col(c) for c in selected_columns])
        
        row_count = df.count()
        logger.info(f"Read {row_count} rows from source")
        return df
    
    def get_clickhouse_connection(self) -> tuple:
        """Get ClickHouse connection details."""
        target_url = os.getenv("CLICKHOUSE_URL", "jdbc:clickhouse://clickhouse:8123")
        target_host = os.getenv("CLICKHOUSE_HOST", "clickhouse")
        target_port = os.getenv("CLICKHOUSE_PORT", "8123")
        target_user = os.getenv("CLICKHOUSE_USER", "default")
        target_password = os.getenv("CLICKHOUSE_PASSWORD", "")
        return target_url, target_host, target_port, target_user, target_password
    
    def ensure_target_table_exists(self):
        """Create target table in ClickHouse if it doesn't exist using proper type mappings."""
        _, target_host, target_port, target_user, target_password = self.get_clickhouse_connection()
        target_table = f"{self.target_config['database']}.{self.target_config['table']}"
        
        # Build column definitions using mapped ClickHouse types
        column_defs = []
{% for col in columns %}
{% if col.name in primary_keys %}
        column_defs.append("`{{ col.name }}` {{ col.data_type | to_clickhouse_type(connection.db_type) }}")
{% else %}
        column_defs.append("`{{ col.name }}` Nullable({{ col.data_type | to_clickhouse_type(connection.db_type) }})")
{% endif %}
{% endfor %}
        
        # Add metadata columns
        column_defs.extend([
            "`_novasight_app_id` String",
            "`_novasight_extracted_at` DateTime64(6) DEFAULT now64()",
            "`_novasight_updated_at` DateTime64(6) DEFAULT now64()",
            "`_novasight_is_deleted` UInt8 DEFAULT 0"
        ])
        
        columns_sql = ",\n    ".join(column_defs)
        
        # Build ORDER BY from primary keys
        order_by_cols = ", ".join([f"`{pk}`" for pk in self.primary_keys])
        
        # Use ReplacingMergeTree for SCD Type 1 (overwrites)
        create_sql = f"""
        CREATE TABLE IF NOT EXISTS {target_table} (
            {columns_sql}
        ) ENGINE = ReplacingMergeTree(_novasight_updated_at)
        ORDER BY ({order_by_cols})
        PRIMARY KEY ({order_by_cols})
        """
        
        logger.info(f"Ensuring target table exists: {target_table}")
        logger.debug(f"Create table DDL:\n{create_sql}")
        
        try:
            # Use ClickHouse HTTP interface to execute DDL
            params = {"query": create_sql}
            if target_user:
                params["user"] = target_user
            if target_password:
                params["password"] = target_password
            
            query_string = urllib.parse.urlencode(params)
            http_url = f"http://{target_host}:{target_port}/?{query_string}"
            
            req = urllib.request.Request(http_url, method='POST')
            with urllib.request.urlopen(req, timeout=30) as response:
                if response.status == 200:
                    logger.info(f"Table {target_table} is ready")
                else:
                    logger.warning(f"Table creation response: {response.read().decode()}")
        except Exception as e:
            logger.warning(f"Could not create table via HTTP, will try JDBC: {e}")
    
    def read_target(self) -> DataFrame:
        """Read existing data from target for comparison."""
        target_url, _, _, target_user, target_password = self.get_clickhouse_connection()
        
        connection_props = {
            "user": target_user,
            "password": target_password,
            "driver": "com.clickhouse.jdbc.ClickHouseDriver",
        }
        
        target_table = f"{self.target_config['database']}.{self.target_config['table']}"
        
        try:
            # Read only primary key columns for matching
            pk_cols = ", ".join(self.primary_keys)
            query = f"SELECT {pk_cols} FROM {target_table}"
            
            return self.spark.read.jdbc(
                url=target_url,
                table=f"({query}) AS target_data",
                properties=connection_props
            )
        except Exception as e:
            logger.warning(f"Could not read target table: {e}")
            # Return empty DataFrame with PK schema
            from pyspark.sql.types import StructType
            return self.spark.createDataFrame([], StructType([]))
    
    def identify_changes(self, source_df: DataFrame, target_df: DataFrame) -> tuple:
        """
        Identify new and updated records.
        
        Returns:
            Tuple of (inserts_df, updates_df)
        """
        # Build join condition on primary keys
        join_condition = [source_df[pk] == target_df[pk] for pk in self.primary_keys]
        
        # Left join to find matches
        joined = source_df.join(
            target_df.select(self.primary_keys).withColumn("_exists", lit(True)),
            on=self.primary_keys,
            how="left"
        )
        
        # New records (no match in target)
        new_records = joined.filter(col("_exists").isNull()).drop("_exists")
        
        # Updated records (match in target)
        updated_records = joined.filter(col("_exists") == True).drop("_exists")
        
        logger.info(f"Identified {new_records.count()} new records and {updated_records.count()} updates")
        
        return new_records, updated_records
    
    def add_metadata_columns(self, df: DataFrame, is_update: bool = False) -> DataFrame:
        """Add metadata columns for audit tracking."""
        current_ts = current_timestamp()
        df = df \
            .withColumn("_novasight_app_id", lit(self.app_id)) \
            .withColumn("_novasight_extracted_at", current_ts) \
            .withColumn("_novasight_updated_at", current_ts) \
            .withColumn("_novasight_is_deleted", lit(0))
        
        return df
    
{% if partitions and partitions|length > 0 %}
    def partition_data(self, df: DataFrame) -> DataFrame:
        """Partition data by configured columns."""
        partition_cols = [
{% for part_col in partitions %}
            "{{ part_col }}",
{% endfor %}
        ]
        return df.repartition(*[col(c) for c in partition_cols])
{% endif %}
    
    def write_to_target(self, inserts_df: DataFrame, updates_df: DataFrame):
        """Write data to ClickHouse target using ReplacingMergeTree."""
        logger.info(f"Writing to target: {self.target_config['database']}.{self.target_config['table']}")
        
        target_url, _, _, target_user, target_password = self.get_clickhouse_connection()
        
        connection_props = {
            "user": target_user,
            "password": target_password,
            "driver": "com.clickhouse.jdbc.ClickHouseDriver",
        }
        
        target_table = f"{self.target_config['database']}.{self.target_config['table']}"
        
        # Combine inserts and updates (SCD Type 1 - just upsert)
        # ReplacingMergeTree in ClickHouse handles the deduplication
        all_data = inserts_df.union(updates_df)
        
{% if partitions and partitions|length > 0 %}
        all_data = self.partition_data(all_data)
{% endif %}
        
        all_data.write.jdbc(
            url=target_url,
            table=target_table,
            mode="append",  # ReplacingMergeTree handles duplicates
            properties=connection_props
        )
        
        total_rows = all_data.count()
        logger.info(f"Successfully wrote {total_rows} rows to target")
        
        return total_rows
    
    def run(self):
        """Execute the SCD Type 1 job."""
        logger.info(f"Starting SCD Type 1 job: {self.app_name}")
        start_time = datetime.now()
        
        try:
            # Ensure target table exists in ClickHouse
            self.ensure_target_table_exists()
            
            # Read source data
            source_df = self.read_source()
            
            if source_df.isEmpty():
                logger.info("No new data to process")
                return {
                    "status": "success",
                    "rows_processed": 0,
                    "rows_inserted": 0,
                    "rows_updated": 0,
                    "duration_seconds": 0,
                }
            
            # Read target for comparison
            target_df = self.read_target()
            
            # Identify changes
            inserts_df, updates_df = self.identify_changes(source_df, target_df)
            
            # Add metadata
            inserts_df = self.add_metadata_columns(inserts_df, is_update=False)
            updates_df = self.add_metadata_columns(updates_df, is_update=True)
            
            # Write to target
            total_written = self.write_to_target(inserts_df, updates_df)
            
{% if cdc.column %}
            # Update high watermark
            max_watermark = source_df.agg({self.cdc_column: "max"}).collect()[0][0]
            if max_watermark:
                self.save_high_watermark(str(max_watermark))
{% endif %}
            
            duration = (datetime.now() - start_time).total_seconds()
            logger.info(f"SCD Type 1 job completed in {duration:.2f} seconds")
            
            return {
                "status": "success",
                "rows_processed": source_df.count(),
                "rows_inserted": inserts_df.count(),
                "rows_updated": updates_df.count(),
                "duration_seconds": duration,
            }
            
        except Exception as e:
            logger.error(f"SCD Type 1 job failed: {str(e)}")
            raise


def main():
    """Main entry point."""
    spark = SparkSession.builder \
        .appName("{{ app_name }}") \
        .config("spark.sql.adaptive.enabled", "true") \
        .config("spark.sql.adaptive.coalescePartitions.enabled", "true") \
        .config("spark.sql.shuffle.partitions", "200") \
        .getOrCreate()
    
    try:
        job = SCDType1Job(spark)
        result = job.run()
        logger.info(f"Job result: {result}")
    finally:
        spark.stop()


if __name__ == "__main__":
    main()
