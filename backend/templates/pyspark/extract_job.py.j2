{#
NovaSight PySpark Extract Job Template
======================================

Generates a PySpark job for extracting data from source to target.
This is the base template for simple data extraction without SCD handling.

Template Version: 1.0.0
Category: pyspark
-#}
"""
PySpark Extract Job: {{ app_name }}
Generated by NovaSight Template Engine
Generated at: {{ generated_at }}
Template Version: {{ template_version }}
App ID: {{ app_id }}
Tenant ID: {{ tenant_id }}

DO NOT MODIFY THIS FILE DIRECTLY.
All changes should be made through the NovaSight UI.
"""

from pyspark.sql import SparkSession
from pyspark.sql.functions import col, lit, current_timestamp
from pyspark.sql.types import *
import logging
import os
from datetime import datetime

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger("{{ app_name }}")


class ExtractJob:
    """
    Extract job for {{ app_name }}.
    
    Source: {{ connection.db_type }} - {{ connection.host }}:{{ connection.port }}/{{ connection.database }}
    Target: {{ target.database }}.{{ target.table }}
    Write Mode: {{ write_mode }}
    Tenant: {{ tenant_id }}
    
    SECURITY: This job is scoped to tenant database only.
    """
    
    # Tenant isolation constants
    TENANT_ID = "{{ tenant_id }}"
    TENANT_DATABASE = os.getenv("TENANT_DATABASE", "{{ target.database }}")
    
    def __init__(self, spark: SparkSession):
        self.spark = spark
        self.app_name = "{{ app_name }}"
        self.app_id = "{{ app_id | default('unknown', true) }}"
        self.tenant_id = self.TENANT_ID
        
        # Source configuration
        self.source_config = {
            "db_type": "{{ connection.db_type }}",
            "host": os.getenv("SOURCE_DB_HOST", "{{ connection.host }}"),
            "port": int(os.getenv("SOURCE_DB_PORT", "{{ connection.port }}")),
            "database": "{{ connection.database }}",
            "schema": "{{ connection.schema | default('public', true) }}",
            "username": os.getenv("SOURCE_DB_USER", "{{ connection.username }}"),
            "password": os.getenv("SOURCE_DB_PASSWORD", "{{ connection.password | default('', true) }}"),
        }
        
        # Target configuration - always use tenant database
        self.target_config = {
            "database": os.getenv("TARGET_DATABASE", self.TENANT_DATABASE),
            "table": "{{ target.table }}",
            "engine": "{{ target.engine | default('MergeTree', true) }}",
        }
        
        # Validate target database belongs to tenant
        self._validate_target_database()
        
        # Job configuration
        self.write_mode = "{{ write_mode }}"
        self.batch_size = {{ options.batch_size | default(10000, true) }}
        
        # Column type mappings: source column -> ClickHouse type
        # Generated from source database type: {{ connection.db_type }}
        self.column_type_mapping = {
{% for col in columns %}
            "{{ col.name }}": "{{ col.data_type | to_clickhouse_type(connection.db_type) }}",
{% endfor %}
        }
        
        # Metadata column types for ClickHouse
        self.metadata_columns = {
            "_novasight_app_id": "String",
            "_novasight_extracted_at": "DateTime64(3)",
            "_novasight_tenant_id": "String",
        }
    
    def _validate_target_database(self):
        """Validate that target database belongs to this tenant."""
        import re
        target_db = self.target_config["database"]
        
        # Check if trying to access another tenant's database
        if target_db.startswith("tenant_") and target_db != self.TENANT_DATABASE:
            raise ValueError(
                f"Security violation: Cannot write to database '{target_db}'. "
                f"This job can only write to '{self.TENANT_DATABASE}'."
            )
        
    def get_jdbc_url(self) -> str:
        """Build JDBC URL based on database type."""
        db_type = self.source_config["db_type"]
        host = self.source_config["host"]
        port = self.source_config["port"]
        database = self.source_config["database"]
        
        jdbc_drivers = {
            "postgresql": f"jdbc:postgresql://{host}:{port}/{database}",
            "mysql": f"jdbc:mysql://{host}:{port}/{database}",
            "oracle": f"jdbc:oracle:thin:@{host}:{port}:{database}",
            "sqlserver": f"jdbc:sqlserver://{host}:{port};databaseName={database}",
        }
        
        return jdbc_drivers.get(db_type, f"jdbc:postgresql://{host}:{port}/{database}")
    
    def get_jdbc_driver(self) -> str:
        """Get JDBC driver class name."""
        drivers = {
            "postgresql": "org.postgresql.Driver",
            "mysql": "com.mysql.cj.jdbc.Driver",
            "oracle": "oracle.jdbc.OracleDriver",
            "sqlserver": "com.microsoft.sqlserver.jdbc.SQLServerDriver",
        }
        return drivers.get(self.source_config["db_type"], "org.postgresql.Driver")
    
    def get_clickhouse_create_table_ddl(self) -> str:
        """
        Generate CREATE TABLE DDL for ClickHouse with proper type mappings.
        
        Returns:
            CREATE TABLE DDL string
        """
        target_db = self.target_config["database"]
        target_table = self.target_config["table"]
        engine = self.target_config["engine"]
        
        # Build column definitions with mapped ClickHouse types
        column_defs = []
        for col_name, ch_type in self.column_type_mapping.items():
            column_defs.append(f"    `{col_name}` Nullable({ch_type})")
        
        # Add metadata columns (not nullable)
        for col_name, ch_type in self.metadata_columns.items():
            column_defs.append(f"    `{col_name}` {ch_type}")
        
        columns_str = ",\n".join(column_defs)
        
{% if target.order_by and target.order_by|length > 0 %}
        order_by_cols = ", ".join(["`{{ col }}`" for col in [{% for col in target.order_by %}"{{ col }}"{{ ", " if not loop.last }}{% endfor %}]])
        order_by_clause = f"ORDER BY ({order_by_cols})"
{% else %}
        order_by_clause = "ORDER BY tuple()"
{% endif %}
        
{% if target.partition_by %}
        partition_clause = "PARTITION BY {{ target.partition_by }}"
{% else %}
        partition_clause = ""
{% endif %}
        
        ddl = f"""
CREATE TABLE IF NOT EXISTS `{target_db}`.`{target_table}`
(
{columns_str}
)
ENGINE = {engine}
{order_by_clause}
{partition_clause}
""".strip()
        
        return ddl
    
    def ensure_target_table(self):
        """
        Ensure the target ClickHouse table exists with correct schema.
        
        Creates the table if it doesn't exist, using the column type mappings
        derived from the source database types.
        """
        import clickhouse_connect
        
        target_url = os.getenv("CLICKHOUSE_HOST", "localhost")
        target_port = int(os.getenv("CLICKHOUSE_PORT", "8123"))
        target_user = os.getenv("CLICKHOUSE_USER", "default")
        target_password = os.getenv("CLICKHOUSE_PASSWORD", "")
        
        try:
            client = clickhouse_connect.get_client(
                host=target_url,
                port=target_port,
                username=target_user,
                password=target_password,
            )
            
            ddl = self.get_clickhouse_create_table_ddl()
            logger.info(f"Creating target table if not exists:\n{ddl}")
            
            client.command(ddl)
            logger.info(f"Target table ensured: {self.target_config['database']}.{self.target_config['table']}")
            
        except Exception as e:
            logger.warning(f"Could not ensure target table via DDL (will rely on JDBC auto-create): {e}")
    
    def read_source(self):
        """Read data from source database."""
        logger.info(f"Reading from source: {self.source_config['database']}")
        
        jdbc_url = self.get_jdbc_url()
        jdbc_driver = self.get_jdbc_driver()
        
        connection_props = {
            "user": self.source_config["username"],
            "password": self.source_config["password"],
            "driver": jdbc_driver,
            "fetchsize": str(self.batch_size),
        }
        
{% if source.type == 'query' %}
        # Read using custom query
        query = """{{ source.query | replace('\n', ' ') }}"""
        
        df = self.spark.read.jdbc(
            url=jdbc_url,
            table=f"({query}) AS subquery",
            properties=connection_props
        )
{% else %}
        # Read from table
        table_name = "{% if source.schema %}{{ source.schema }}.{% endif %}{{ source.table }}"
        
        df = self.spark.read.jdbc(
            url=jdbc_url,
            table=table_name,
            properties=connection_props
        )
{% endif %}
        
        # Select only configured columns
        selected_columns = [
{% for col in columns %}
            "{{ col.name }}",
{% endfor %}
        ]
        
        df = df.select([col(c) for c in selected_columns])
        
        logger.info(f"Read {df.count()} rows from source")
        return df
    
    def add_metadata_columns(self, df):
        """Add metadata columns for audit tracking."""
        return df \
            .withColumn("_novasight_app_id", lit(self.app_id)) \
            .withColumn("_novasight_extracted_at", current_timestamp()) \
            .withColumn("_novasight_tenant_id", lit("{{ tenant_id }}"))
    
{% if partitions and partitions|length > 0 %}
    def partition_data(self, df):
        """Partition data by configured columns."""
        partition_cols = [
{% for part_col in partitions %}
            "{{ part_col }}",
{% endfor %}
        ]
        return df.repartition(*[col(c) for c in partition_cols])
{% endif %}
    
    def write_to_target(self, df):
        """Write data to ClickHouse target."""
        logger.info(f"Writing to target: {self.target_config['database']}.{self.target_config['table']}")
        
        target_url = os.getenv("CLICKHOUSE_URL", "jdbc:clickhouse://localhost:8123")
        target_user = os.getenv("CLICKHOUSE_USER", "default")
        target_password = os.getenv("CLICKHOUSE_PASSWORD", "")
        
        connection_props = {
            "user": target_user,
            "password": target_password,
            "driver": "com.clickhouse.jdbc.ClickHouseDriver",
        }
        
        target_table = f"{self.target_config['database']}.{self.target_config['table']}"
        
{% if write_mode == 'append' %}
        df.write.jdbc(
            url=target_url,
            table=target_table,
            mode="append",
            properties=connection_props
        )
{% elif write_mode == 'overwrite' %}
        df.write.jdbc(
            url=target_url,
            table=target_table,
            mode="overwrite",
            properties=connection_props
        )
{% elif write_mode == 'merge' %}
        # For merge, we need to use a staging table approach
        staging_table = f"{target_table}_staging_{datetime.now().strftime('%Y%m%d%H%M%S')}"
        
        # Write to staging
        df.write.jdbc(
            url=target_url,
            table=staging_table,
            mode="overwrite",
            properties=connection_props
        )
        
        # Merge from staging to target
        # Note: ClickHouse merge is handled differently
        logger.info(f"Merge staging {staging_table} -> {target_table}")
{% endif %}
        
        logger.info(f"Successfully wrote {df.count()} rows to target")
    
    def run(self):
        """Execute the extract job."""
        logger.info(f"Starting extract job: {self.app_name}")
        start_time = datetime.now()
        
        try:
            # Ensure target table exists with correct schema
            self.ensure_target_table()
            
            # Read source data
            df = self.read_source()
            
            # Add metadata columns
            df = self.add_metadata_columns(df)
            
{% if partitions and partitions|length > 0 %}
            # Partition data
            df = self.partition_data(df)
{% endif %}
            
            # Write to target
            self.write_to_target(df)
            
            duration = (datetime.now() - start_time).total_seconds()
            logger.info(f"Extract job completed in {duration:.2f} seconds")
            
            return {
                "status": "success",
                "rows_processed": df.count(),
                "duration_seconds": duration,
            }
            
        except Exception as e:
            logger.error(f"Extract job failed: {str(e)}")
            raise


def main():
    """Main entry point."""
    spark = SparkSession.builder \
        .appName("{{ app_name }}") \
        .config("spark.sql.adaptive.enabled", "true") \
        .config("spark.sql.shuffle.partitions", "auto") \
        .getOrCreate()
    
    try:
        job = ExtractJob(spark)
        result = job.run()
        logger.info(f"Job result: {result}")
    finally:
        spark.stop()


if __name__ == "__main__":
    main()
