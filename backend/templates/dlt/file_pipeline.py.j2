def file_records() -> Iterator[List[Dict[str, Any]]]:
    """Yield record batches from the uploaded file."""
    if FILE_FORMAT not in _READERS:
        raise ValueError(f"Unsupported file_format: {FILE_FORMAT}")
    yield from _READERS[FILE_FORMAT]()


def get_destination():
    """Create the dlt destination for the raw lake layer on S3."""
    destination = dlt.destinations.filesystem(
        bucket_url=f"s3://{TENANT_S3_BUCKET}/lake/{DATASET_NAME}",
        credentials={
            "aws_access_key_id": S3_ACCESS_KEY,
            "aws_secret_access_key": S3_SECRET_KEY,
            "endpoint_url": S3_ENDPOINT_URL if S3_ENDPOINT_URL else None,
            "region_name": S3_REGION,
        },
        layout="{table_name}/{load_id}.{file_id}.{ext}",
    )
    return destination


def run_pipeline() -> int:
    """Execute the dlt pipeline."""
    logger.info(f"Starting file pipeline: {PIPELINE_NAME}")
    logger.info(f"Tenant: {TENANT_SLUG} ({TENANT_ID})")
    logger.info(f"File: s3://{TENANT_S3_BUCKET}/{FILE_OBJECT_KEY} ({FILE_FORMAT})")
    logger.info(f"Target: {ICEBERG_NAMESPACE}.{ICEBERG_TABLE}")
    logger.info(f"Write disposition: {WRITE_DISPOSITION}")

    start_time = datetime.utcnow()

    try:
        pipeline = dlt.pipeline(
            pipeline_name=PIPELINE_NAME,
            destination=get_destination(),
            dataset_name=DATASET_NAME,
        )

        info = pipeline.run(file_records())

        duration_ms = int((datetime.utcnow() - start_time).total_seconds() * 1000)

        logger.info("Pipeline completed successfully")
        logger.info(f"Duration: {duration_ms}ms")
        logger.info(f"Load info: {info}")

        # ------------------------------------------------------------------
        # Optional: materialize the freshly-written JSONL load package as
        # an Iceberg table. Gated on ENABLE_ICEBERG so the existing
        # JSONL-on-S3 + ClickHouse-via-s3() path keeps working when the
        # platform Postgres catalog is unreachable.
        # ------------------------------------------------------------------
        if os.environ.get("ENABLE_ICEBERG", "").lower() in ("1", "true", "yes"):
            try:
                from app.platform.lake.iceberg_writer import (
                    materialize_jsonl_to_iceberg,
                )

                # dlt's filesystem destination writes to:
                #   s3://{bucket}/lake/{DATASET_NAME}/{DATASET_NAME}/{table}/*.jsonl
                # because the destination prepends ``dataset_name`` to the
                # configured ``bucket_url`` path.
                jsonl_glob = (
                    f"s3://{TENANT_S3_BUCKET}/lake/{DATASET_NAME}/"
                    f"{DATASET_NAME}/{ICEBERG_TABLE}/*.jsonl"
                )
                ice_result = materialize_jsonl_to_iceberg(
                    tenant_id=TENANT_ID,
                    namespace=ICEBERG_NAMESPACE,
                    table_name=ICEBERG_TABLE,
                    jsonl_glob=jsonl_glob,
                    write_disposition=WRITE_DISPOSITION,
                    s3_endpoint_url=S3_ENDPOINT_URL or None,
                    s3_access_key=S3_ACCESS_KEY,
                    s3_secret_key=S3_SECRET_KEY,
                    s3_region=S3_REGION,
                )
                logger.info("Iceberg post-load: %s", ice_result)
                print(f"METRICS:iceberg_snapshot_id={ice_result.get('snapshot_id')}")
                print(f"METRICS:iceberg_rows={ice_result.get('rows')}")
            except Exception as ice_err:  # noqa: BLE001
                # Iceberg materialization is best-effort. Failing here
                # would discard a successful dlt load — not desired.
                logger.error("Iceberg post-load failed (non-fatal): %s", ice_err)
                print(f"METRICS:iceberg_error={str(ice_err)[:300]}")

        rows = getattr(info, "rows_processed", 0) or 0
        print(f"METRICS:rows={rows}")
        print(f"METRICS:duration_ms={duration_ms}")
        print(f"METRICS:status=success")
        return 0

    except Exception as e:
        duration_ms = int((datetime.utcnow() - start_time).total_seconds() * 1000)
        logger.error(f"Pipeline failed: {e}")
        print(f"METRICS:duration_ms={duration_ms}")
        print(f"METRICS:status=error")
        print(f"METRICS:error={str(e)[:500]}")
        return 1


if __name__ == "__main__":
    sys.exit(run_pipeline())
