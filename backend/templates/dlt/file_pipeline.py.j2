    return opts


def _s3_url() -> str:
    """Resolve the s3:// URL for the uploaded file."""
    return f"s3://{TENANT_S3_BUCKET}/{FILE_OBJECT_KEY}"


def _project_columns(records: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    """Project to selected columns if any."""
    if not COLUMNS:
        return records
    cols = set(COLUMNS)
    return [{k: v for k, v in r.items() if k in cols} for r in records]


def _read_csv_records() -> Iterator[List[Dict[str, Any]]]:
    """Stream CSV/TSV in chunks."""
    import pandas as pd

    delimiter = FILE_OPTIONS.get("delimiter") or ("\t" if FILE_FORMAT == "tsv" else ",")
    encoding = FILE_OPTIONS.get("encoding", "utf-8")
    header_row = FILE_OPTIONS.get("header_row", 0)
    chunksize = int(FILE_OPTIONS.get("chunksize", 50_000))
    na_values = FILE_OPTIONS.get("na_values")

    reader = pd.read_csv(
        _s3_url(),
        sep=delimiter,
        encoding=encoding,
        header=header_row,
        chunksize=chunksize,
        na_values=na_values,
        storage_options=_build_storage_options(),
        low_memory=False,
    )
    for chunk in reader:
        yield _project_columns(chunk.to_dict(orient="records"))


def _read_excel_records() -> Iterator[List[Dict[str, Any]]]:
    """Read a single Excel sheet (Excel cannot stream)."""
    import pandas as pd

    sheet = FILE_OPTIONS.get("sheet_name", 0)
    header_row = FILE_OPTIONS.get("header_row", 0)
    df = pd.read_excel(
        _s3_url(),
        sheet_name=sheet,
        header=header_row,
        storage_options=_build_storage_options(),
        engine="openpyxl" if FILE_FORMAT == "xlsx" else None,
    )
    yield _project_columns(df.to_dict(orient="records"))


def _read_parquet_records() -> Iterator[List[Dict[str, Any]]]:
    """Stream Parquet by row-group batches."""
    import pyarrow.parquet as pq
    import s3fs

    fs = s3fs.S3FileSystem(
        key=S3_ACCESS_KEY,
        secret=S3_SECRET_KEY,
        client_kwargs={
            **({"endpoint_url": S3_ENDPOINT_URL} if S3_ENDPOINT_URL else {}),
            "region_name": S3_REGION,
        },
    )
    with fs.open(_s3_url(), "rb") as f:
        pf = pq.ParquetFile(f)
        batch_size = int(FILE_OPTIONS.get("batch_size", 50_000))
        for batch in pf.iter_batches(batch_size=batch_size):
            df = batch.to_pandas()
            yield _project_columns(df.to_dict(orient="records"))


def _read_json_records() -> Iterator[List[Dict[str, Any]]]:
    """Read JSON document or stream JSONL/NDJSON."""
    import pandas as pd

    if FILE_FORMAT == "jsonl":
        chunksize = int(FILE_OPTIONS.get("chunksize", 50_000))
        reader = pd.read_json(
            _s3_url(),
            lines=True,
            chunksize=chunksize,
            storage_options=_build_storage_options(),
        )
        for chunk in reader:
            yield _project_columns(chunk.to_dict(orient="records"))
    else:
        orient = FILE_OPTIONS.get("orient", "records")
        df = pd.read_json(
            _s3_url(),
            orient=orient,
            storage_options=_build_storage_options(),
        )
        yield _project_columns(df.to_dict(orient="records"))


_READERS = {
    "csv": _read_csv_records,
    "tsv": _read_csv_records,
    "xlsx": _read_excel_records,
    "xls": _read_excel_records,
    "parquet": _read_parquet_records,
    "json": _read_json_records,
    "jsonl": _read_json_records,
}


