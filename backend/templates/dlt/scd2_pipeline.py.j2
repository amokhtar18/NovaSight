        bucket_url=f"s3://{TENANT_S3_BUCKET}/iceberg/{ICEBERG_NAMESPACE}",
        credentials={
            "aws_access_key_id": S3_ACCESS_KEY,
            "aws_secret_access_key": S3_SECRET_KEY,
            "endpoint_url": S3_ENDPOINT_URL if S3_ENDPOINT_URL else None,
            "region_name": S3_REGION,
        },
        layout="{table_name}",
        destination_name="iceberg",
    )
    
    return destination


def run_pipeline():
    """Execute the dlt SCD2 pipeline."""
    logger.info(f"Starting SCD2 pipeline: {PIPELINE_NAME}")
    logger.info(f"Tenant: {TENANT_SLUG} ({TENANT_ID})")
    logger.info(f"Target: {ICEBERG_NAMESPACE}.{ICEBERG_TABLE}")
    logger.info(f"Primary keys: {PRIMARY_KEY_COLUMNS}")
    logger.info(f"SCD2 columns: {SCD2_VALID_FROM_COLUMN}, {SCD2_VALID_TO_COLUMN}")
    
    start_time = datetime.utcnow()
    
    try:
        # Create pipeline
        pipeline = dlt.pipeline(
            pipeline_name=PIPELINE_NAME,
            destination=get_destination(),
            dataset_name=ICEBERG_NAMESPACE,
        )
        
        # Get source data (DltResource for table, custom resource for query)
        source = get_source()

        # Apply SCD2 hints. NOTE: sql_database `.select(*names)` selects
        # resources by name and does not perform column projection; column
        # projection should be handled in the source query if needed.
        # dlt native SCD2 support adds validity columns automatically
        source.apply_hints(
            primary_key=RUNTIME_PRIMARY_KEY_COLUMNS,
            write_disposition={
                "disposition": "merge",
                "strategy": "scd2",
                "validity_column_names": [SCD2_VALID_FROM_COLUMN, SCD2_VALID_TO_COLUMN],
                "active_record_timestamp": None,  # NULL means current record
            },
        )
        
        # Run the pipeline with SCD2 merge
        info = pipeline.run(
            source,
            table_name=ICEBERG_TABLE,
        )
        
        # Calculate stats
        duration_ms = int((datetime.utcnow() - start_time).total_seconds() * 1000)
        
        # Log results
        logger.info(f"SCD2 pipeline completed successfully")
        logger.info(f"Duration: {duration_ms}ms")
        logger.info(f"Load info: {info}")
        
        # Output metrics for Dagster
        _rows = getattr(info, "rows_processed", None)
        if _rows is None:
            _rows = 0
            for _pkg in getattr(info, "load_packages", []) or []:
                for _job in getattr(_pkg, "jobs", {}).get("completed_jobs", []) or []:
                    _rows += getattr(_job, "rows_count", 0) or 0
        print(f"METRICS:rows={_rows}")
        print(f"METRICS:duration_ms={duration_ms}")
        print(f"METRICS:status=success")
        
        return 0
        
    except Exception as e:
        duration_ms = int((datetime.utcnow() - start_time).total_seconds() * 1000)
        logger.exception(f"SCD2 pipeline failed ({type(e).__name__}): {e}")
        print(f"METRICS:duration_ms={duration_ms}")
        print(f"METRICS:status=error")
        print(f"METRICS:error={str(e)[:500]}")
        return 1


if __name__ == "__main__":
    sys.exit(run_pipeline())
