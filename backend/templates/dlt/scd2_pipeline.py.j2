def get_source():
    """Create the dlt source/resource for data extraction."""
    {% if source_type == "table" %}
    # sql_table reflection can fail against some Oracle sources with
    # NoSuchTableError even when the table exists; use direct SQL for Oracle.
    if IS_ORACLE_SOURCE:
        import sqlalchemy as _sa

        def _quote_ident(name: str) -> str:
            return '"' + str(name).replace('"', '""') + '"'

        _columns_sql = ", ".join(_quote_ident(col) for col in COLUMNS) if COLUMNS else "*"
        _table_sql = _quote_ident(SOURCE_TABLE)
        if SOURCE_SCHEMA:
            _table_sql = f"{_quote_ident(SOURCE_SCHEMA)}.{_table_sql}"
        _source_query = f"SELECT {_columns_sql} FROM {_table_sql}"

        @dlt.resource(name=ICEBERG_TABLE)
        def _oracle_table_resource(
            {% if incremental_cursor_column %}
            cursor=dlt.sources.incremental(RUNTIME_INCREMENTAL_CURSOR_COLUMN, initial_value=None),
            {% endif %}
        ):
            engine = _sa.create_engine(SOURCE_CONNECTION_STRING)
            with engine.connect() as conn:
                result = conn.execute(_sa.text(_source_query))
                cols = list(result.keys())
                for row in result:
                    payload = dict(zip(cols, row))
                    yield {str(k).lower(): v for k, v in payload.items()}

        source = _oracle_table_resource
    else:
        # Extract from a single table using sql_table (returns a DltResource).
        # sql_table accepts the `incremental` argument; sql_database does not.
        source = sql_table(
            credentials=SOURCE_CONNECTION_STRING,
            schema="{{ source_schema }}",
            table="{{ source_table }}",
            {% if incremental_cursor_column %}
            incremental=dlt.sources.incremental(
                cursor_path="{{ incremental_cursor_column }}",
                initial_value=None,
            ),
            {% endif %}
        )
    {% else %}
    # Extract from a custom SQL query via a dlt resource.
    import sqlalchemy as _sa

    @dlt.resource(name=ICEBERG_TABLE)
    def _query_resource(
        {% if incremental_cursor_column %}
        cursor=dlt.sources.incremental(RUNTIME_INCREMENTAL_CURSOR_COLUMN, initial_value=None),
        {% endif %}
    ):
