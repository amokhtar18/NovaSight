{% raw %}{{{% endraw %}
  config(
    materialized='{{ materialized | default("view") }}',
    tags=['staging', '{{ source_name | default("iceberg") }}']
  )
{% raw %}}}{% endraw %}

{#-
Staging layer: minimal transformation, 1:1 with source.

Source resolution depends on ``source_kind``:
  * ``warehouse``  → reads from a dbt ``source()`` (a ClickHouse table
                     declared in a sources.yml file).
  * ``iceberg``    → reads from an Iceberg table on the tenant's S3
                     bucket via ClickHouse's native ``iceberg()`` table
                     function. The model still materializes into the
                     tenant's ClickHouse database (single materialization
                     target — see profiles.yml).
-#}

WITH source AS (
    SELECT *
{% if source_kind | default('warehouse') == 'iceberg' %}
    FROM iceberg('{{ iceberg_s3_uri }}')
{% else %}
    FROM {% raw %}{{ source('{% endraw %}{{ source_name }}{% raw %}', '{% endraw %}{{ source_table }}{% raw %}') }}{% endraw %}

{% endif %}
),

renamed AS (
    SELECT
{% if primary_key is defined and primary_key %}
        -- Primary key
        {{ primary_key }} AS {{ primary_key }},
{% endif %}
{% if tenant_column | default('tenant_id') %}
        -- Tenant isolation
        {{ tenant_column | default('tenant_id') }} AS tenant_id,
{% endif %}
{% for col in columns %}
{% if col.name != primary_key and col.name != (tenant_column | default('tenant_id')) %}
        -- {{ col.description | default(col.name) }}
{% if col.cast is defined and col.cast %}
        CAST({{ col.source_name | default(col.name) }} AS {{ col.cast }}) AS {{ col.alias | default(col.name) }}{% if not loop.last %},{% endif %}

{% elif col.alias is defined and col.alias != col.name %}
        {{ col.source_name | default(col.name) }} AS {{ col.alias }}{% if not loop.last %},{% endif %}

{% else %}
        {{ col.source_name | default(col.name) }}{% if not loop.last %},{% endif %}

{% endif %}
{% endif %}
{% endfor %}
    FROM source
)

SELECT * FROM renamed
