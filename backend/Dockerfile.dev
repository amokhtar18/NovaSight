# NovaSight Backend Development Dockerfile
# =========================================
# Single-stage build with Flask + Dagster via supervisord.
#
# Build context: REPOSITORY ROOT (so the image can reach both `backend/`
# and `dbt/` for the dbt-deps bake step).
#
# Build manually with:
#   docker build -f backend/Dockerfile.dev -t novasight-backend:dev .
# (docker-compose.yml already wires this up via `context: .`).

FROM python:3.11-slim

# ── Environment ──
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    FLASK_APP=app \
    FLASK_ENV=development \
    DEBIAN_FRONTEND=noninteractive \
    LD_LIBRARY_PATH=/opt/oracle/instantclient_23_5:$LD_LIBRARY_PATH \
    DAGSTER_HOME=/app/orchestration \
    DBT_PACKAGES_INSTALL_PATH=/var/dbt_packages

WORKDIR /app

# ── OS dependencies ──
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    libpq-dev \
    build-essential \
    curl \
    git \
    libaio1t64 \
    wget \
    unzip \
    supervisor \
    openssh-client \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/lib/x86_64-linux-gnu/libaio.so.1t64 /usr/lib/x86_64-linux-gnu/libaio.so.1

# ── Oracle Instant Client (thick mode for older Oracle DBs) ──
RUN mkdir -p /opt/oracle && \
    wget -q https://download.oracle.com/otn_software/linux/instantclient/2350000/instantclient-basiclite-linux.x64-23.5.0.24.07.zip -O /tmp/instantclient.zip && \
    unzip -q /tmp/instantclient.zip -d /opt/oracle && \
    rm /tmp/instantclient.zip && \
    echo /opt/oracle/instantclient_23_5 > /etc/ld.so.conf.d/oracle-instantclient.conf && \
    ldconfig

# ── Python dependencies (includes dbt-core, dbt-duckdb, dbt-clickhouse) ──
COPY backend/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/requirements-dev.txt* ./
RUN if [ -f requirements-dev.txt ]; then pip install --no-cache-dir -r requirements-dev.txt; fi

# ── Pre-install dbt packages into the image ──
# Resolves dbt_utils / dbt_expectations at build time so containers don't
# need network access on first run, and so the bind-mounted /app/dbt
# project doesn't get corrupted on Windows (see the note in
# dbt/dbt_project.yml about packages-install-path).
COPY dbt/packages.yml dbt/dbt_project.yml /tmp/dbt-deps/
RUN mkdir -p "$DBT_PACKAGES_INSTALL_PATH" \
    && dbt deps \
        --project-dir /tmp/dbt-deps \
        --profiles-dir /tmp/dbt-deps \
    && rm -rf /tmp/dbt-deps

# ── Application code ──
COPY backend/ /app/

# Runtime directories
RUN mkdir -p /var/log/supervisor /var/dagster/logs

# Supervisor config
COPY backend/supervisord.conf /etc/supervisor/conf.d/supervisord.conf

# Ports: Flask=5000, Dagster=3000
EXPOSE 5000 3000

# Entrypoint executable
RUN chmod +x /app/entrypoint.sh 2>/dev/null || true

# Entrypoint runs migrations + seed, then exec's CMD
ENTRYPOINT ["/app/entrypoint.sh"]

# Run with supervisord to manage Flask + Dagster
CMD ["supervisord", "-c", "/etc/supervisor/conf.d/supervisord.conf"]
