{#
NovaSight Base DAG Component
============================

This template contains the common imports, configuration, and base structure
used across all NovaSight DAG templates.

Provides:
- Standard imports
- Default arguments
- Spark configuration
- Common utilities
#}
{% macro header(dag_id, version, owner, description='') %}
"""
Auto-generated NovaSight DAG
============================

DAG ID: {{ dag_id }}
Version: {{ version | default(1) }}
Generated: {{ generated_at | default(now().isoformat()) }}
Owner: {{ owner | default('novasight') }}
{% if description %}
Description: {{ description }}
{% endif %}

WARNING: This file is auto-generated by NovaSight.
Do not edit manually - changes will be overwritten.

Spark submission modes:
- Native: Uses SparkSubmitOperator with local Spark installation
- Docker: Uses BashOperator with docker exec (fallback)
"""
{% endmacro %}

{% macro imports(use_spark=true, use_dbt=false, use_email=false, use_http_sensor=false, use_external_task=false) %}
from __future__ import annotations

import os
from datetime import datetime, timedelta
import pendulum
from airflow.models.dag import DAG
from airflow.providers.standard.operators.python import PythonOperator
from airflow.providers.standard.operators.bash import BashOperator
from airflow.providers.standard.operators.empty import EmptyOperator
from airflow.utils.task_group import TaskGroup
from airflow.task.trigger_rule import TriggerRule
{% if use_spark %}
from airflow.providers.apache.spark.operators.spark_submit import SparkSubmitOperator
{% endif %}
{% if use_email %}
from airflow.providers.smtp.operators.smtp import EmailOperator
{% endif %}
{% if use_http_sensor %}
from airflow.providers.http.sensors.http import HttpSensor
{% endif %}
{% if use_external_task %}
from airflow.sensors.external_task import ExternalTaskSensor
{% endif %}
{% if use_dbt %}
# BashOperator already imported above for dbt commands
{% endif %}
{% endmacro %}

{% macro spark_config() %}
# ============================================
# Spark Configuration
# ============================================
# Use native Spark (preferred) or Docker exec (fallback)
SPARK_HOME = os.environ.get('SPARK_HOME', '/opt/spark')
SPARK_MASTER = os.environ.get('SPARK_MASTER', 'spark://spark-master:7077')
SPARK_MASTER_CONTAINER = os.environ.get('SPARK_MASTER_CONTAINER', 'novasight-spark-master')

# Check if native Spark is available
SPARK_NATIVE_AVAILABLE = os.path.exists(f'{SPARK_HOME}/bin/spark-submit')
{% endmacro %}

{% macro default_args(owner, retries=2, retry_delay_minutes=5, email=none, email_on_failure=false, email_on_success=false, execution_timeout_hours=2) %}
default_args = {
    'owner': '{{ owner | default("novasight") }}',
    'depends_on_past': False,
    'retries': {{ retries }},
    'retry_delay': timedelta(minutes={{ retry_delay_minutes }}),
    'execution_timeout': timedelta(hours={{ execution_timeout_hours }}),
{% if email %}
    'email': {{ email | tojson }},
    'email_on_failure': {{ email_on_failure | lower | capitalize }},
    'email_on_success': {{ email_on_success | lower | capitalize }},
{% else %}
    'email_on_failure': False,
    'email_on_success': False,
{% endif %}
}
{% endmacro %}

{% macro tenant_context(tenant_id, tenant_slug=none, tenant_database=none) %}
# ============================================
# Tenant Isolation Context (ADR-003)
# ============================================
TENANT_ID = '{{ tenant_id }}'
TENANT_SLUG = '{{ tenant_slug | default(tenant_id) }}'
TENANT_DATABASE = '{{ tenant_database | default("tenant_" ~ (tenant_slug | default(tenant_id))) }}'
{% endmacro %}

{% macro dbt_config(project_dir='/opt/airflow/dbt', profiles_dir='/opt/airflow/dbt', target='prod') %}
# ============================================
# dbt Configuration
# ============================================
DBT_PROJECT_DIR = '{{ project_dir }}'
DBT_PROFILES_DIR = '{{ profiles_dir }}'
DBT_TARGET = '{{ target }}'
{% endmacro %}
