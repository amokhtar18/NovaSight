#}
"""
Transformation DAG for Tenant: {{ tenant_id }}
Datasource: {{ datasource_name }}
Generated by NovaSight Template Engine

DAG ID: {{ dag_id }}
Waits for: {{ ingestion_dag_id }}

WARNING: This file is auto-generated by NovaSight.
Do not edit manually - changes will be overwritten.
"""

from datetime import datetime, timedelta
from airflow import DAG
from airflow.operators.bash import BashOperator
from airflow.operators.empty import EmptyOperator
from airflow.sensors.external_task import ExternalTaskSensor
from airflow.utils.task_group import TaskGroup
from airflow.utils.trigger_rule import TriggerRule

# Default arguments for the DAG
default_args = {
    'owner': 'novasight',
    'depends_on_past': False,
    'email_on_failure': True,
    'email_on_retry': False,
    'retries': {{ retries | default(2) }},
    'retry_delay': timedelta(minutes={{ retry_delay_minutes | default(5) }}),
    'execution_timeout': timedelta(hours={{ execution_timeout_hours | default(3) }}),
}

# dbt configuration
DBT_PROJECT_DIR = '{{ dbt_project_dir | default('/opt/airflow/dbt') }}'
DBT_PROFILES_DIR = '{{ dbt_profiles_dir | default('/opt/airflow/dbt') }}'
DBT_TARGET = '{{ dbt_target | default('prod') }}'
TENANT_ID = '{{ tenant_id }}'
TENANT_DATABASE = 'tenant_{{ tenant_id }}'

with DAG(
    dag_id='{{ dag_id }}',
    description='dbt transformations for {{ datasource_name }} (tenant: {{ tenant_id }})',
    schedule='{{ schedule | default('@hourly') }}',
    start_date=datetime({{ start_date | default('2024-01-01') | replace('-', ', ') }}),
    catchup={{ catchup | default(false) | lower | capitalize }},
    default_args=default_args,
    tags=['transform', 'dbt', 'tenant_{{ tenant_id }}', '{{ datasource_name }}'],
    max_active_runs=1,
) as dag:
    
    # Start marker
    start = EmptyOperator(task_id='start')
    
    # Wait for ingestion to complete
    wait_for_ingestion = ExternalTaskSensor(
        task_id='wait_for_ingestion',
        external_dag_id='{{ ingestion_dag_id }}',
        external_task_id=None,  # Wait for entire DAG
        allowed_states=['success'],
        failed_states=['failed', 'skipped'],
        mode='reschedule',
        timeout=3600,
        poke_interval=60,
    )
    
{% for task in tasks %}
    # Task: {{ task.description | default(task.task_id) }}
    {{ task.task_id }} = BashOperator(
        task_id='{{ task.task_id }}',
        bash_command='''
            set -e
            cd {{ dbt_project_dir | default('/opt/airflow/dbt') }} && \
            dbt {{ task.dbt_command }} \
                --select {{ task.select }} \
                --vars '{"tenant_id": "{{ tenant_id }}"}' \
                --target {{ dbt_target | default('prod') }} \
                --profiles-dir {{ dbt_profiles_dir | default('/opt/airflow/dbt') }}
        ''',
        env={
            'DBT_PROFILES_DIR': DBT_PROFILES_DIR,
            'TENANT_ID': TENANT_ID,
            'TENANT_DATABASE': TENANT_DATABASE,
        },
        execution_timeout=timedelta(minutes={{ task.timeout_minutes | default(60) }}),
    )
{% endfor %}
    
    # End marker
    end = EmptyOperator(
        task_id='end',
        trigger_rule=TriggerRule.ALL_DONE,
    )
    
    # Task dependencies
    start >> wait_for_ingestion
{% if tasks | length > 0 %}
    wait_for_ingestion >> {{ tasks[0].task_id }}
{% for i in range(1, tasks | length) %}
    {{ tasks[i-1].task_id }} >> {{ tasks[i].task_id }}
{% endfor %}
    {{ tasks[-1].task_id }} >> end
{% else %}
    wait_for_ingestion >> end
{% endif %}
