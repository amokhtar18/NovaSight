# =============================================================================
# NovaSight S3 / Object Storage configuration
# =============================================================================
# Variables consumed by:
#   - dlt pipelines (writing Iceberg tables)
#   - dbt-duckdb (reading Iceberg tables as sources)
#   - Iceberg SQL catalog
#
# Copy to `.env` (or merge into your environment) and adjust per deployment.
# =============================================================================

# ---- S3 endpoint ------------------------------------------------------------
# For AWS:        leave S3_ENDPOINT_URL empty and set AWS_REGION.
# For MinIO/dev:  point S3_ENDPOINT_URL to the MinIO service.
S3_ENDPOINT_URL=http://minio:9000
AWS_REGION=us-east-1
S3_USE_SSL=false
S3_URL_STYLE=path

# ---- Credentials ------------------------------------------------------------
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ---- Bucket layout ----------------------------------------------------------
# Per-tenant bucket pattern. {slug} is replaced by the tenant slug.
S3_BUCKET_PATTERN=novasight-{slug}
# Default region applied when provisioning new tenant buckets.
S3_DEFAULT_REGION=us-east-1

# ---- Iceberg catalog --------------------------------------------------------
# Postgres-backed Iceberg SQL catalog (shared metadata, per-tenant namespaces).
ICEBERG_CATALOG_TYPE=sql
ICEBERG_CATALOG_NAME=novasight
ICEBERG_CATALOG_URI=postgresql://novasight:novasight@postgres:5432/novasight_platform
ICEBERG_WAREHOUSE=s3://novasight/

# ---- DuckDB (used by dbt-duckdb lake target) --------------------------------
DUCKDB_THREADS=4
DUCKDB_MEMORY_LIMIT=4GB
