{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TenantReadWrite",
      "Effect": "Allow",
      "Principal": {
        "AWS": ["arn:aws:iam::${ACCOUNT_ID}:role/novasight-${TENANT_SLUG}"]
      },
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:AbortMultipartUpload",
        "s3:ListMultipartUploadParts"
      ],
      "Resource": [
        "arn:aws:s3:::novasight-${TENANT_SLUG}",
        "arn:aws:s3:::novasight-${TENANT_SLUG}/*"
      ]
    },
    {
      "Sid": "DenyInsecureTransport",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::novasight-${TENANT_SLUG}",
        "arn:aws:s3:::novasight-${TENANT_SLUG}/*"
      ],
      "Condition": {
        "Bool": {
          "aws:SecureTransport": "false"
        }
      }
    }
  ]
}
