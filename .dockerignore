# Repository-root .dockerignore
# =============================
# Used because backend/Dockerfile.dev and backend/Dockerfile now build with
# context = repository root (so they can reach both backend/ and dbt/ for
# the dbt-deps bake step). Keep the build context small.

# VCS / IDE
.git
.gitignore
.github
.vscode
.idea

# Python virtualenvs and caches
.venv
**/.venv
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/htmlcov
**/coverage*
**/.coverage*

# Frontend build outputs and deps
frontend/node_modules
frontend/dist
frontend/build
frontend/playwright-report
frontend/test-results
frontend/.next
frontend/.turbo

# dbt artifacts (we only want packages.yml / dbt_project.yml + sources)
dbt/target
dbt/dbt_packages
dbt/logs

# Backend artifacts
backend/file_storage
backend/test_output.txt
backend/migrations_backup

# Logs / reports / scratch
logs
**/*.log
performance/**/results
security/reports
docs/site

# OS noise
**/.DS_Store
Thumbs.db

# Docker self-references
**/Dockerfile*~
docker-compose*.override.local.yml
